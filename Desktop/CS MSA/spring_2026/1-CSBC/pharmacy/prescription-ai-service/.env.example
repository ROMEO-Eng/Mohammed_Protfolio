# FastAPI Configuration
APP_NAME="Prescription AI Service"
APP_VERSION="0.1.0"
DEBUG=false
ENVIRONMENT=development

# Server Configuration
HOST=0.0.0.0
PORT=8001
RELOAD=true

# Database Configuration
MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=pharmacy_ai
MONGODB_TIMEOUT=5000

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Authentication & Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Spring Boot Backend Integration
SPRING_BOOT_BASE_URL=http://localhost:8080
SPRING_BOOT_API_KEY=your-api-key-for-spring-boot

# OCR Configuration
OCR_LANGUAGE=en
OCR_USE_GPU=false
OCR_CONFIDENCE_THRESHOLD=0.5

# LLM Configuration
LLM_MODEL_TYPE=qwen  # Options: qwen, llama
QWEN_MODEL_NAME=Qwen/Qwen1.5-7B-Chat
LLAMA_MODEL_NAME=meta-llama/Llama-2-7b-chat-hf
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# File Storage
FILE_UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
RETENTION_DAYS=30

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Monitoring
PROMETHEUS_METRICS_ENABLED=true
SENTRY_DSN=

# Medical Terminology Database
MEDICAL_DB_PATH=./data/medical_terminology.json
DRUG_SYNONYMS_PATH=./data/drug_synonyms.json